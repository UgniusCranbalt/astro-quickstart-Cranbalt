---
const title = "Cranbalt | Tower Crane Rental & Industrial Crane Manufacturing";
const description = "Cranbalt offers tower crane rental (8-40t) and manufacturing of industrial cranes & steel structures in Sweden, Norway, Baltics. High-quality lifting solutions since 1966.";
---

<html lang="lt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://cranbalt.com/" />

  <!-- Open Graph / Social -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://cranbalt.com/" />
  <meta property="og:image" content="https://cranbalt.com/wp-content/uploads/2018/03/Tower-crane-rental-sweden-cranbalt-336x180.jpg" />
  <meta property="og:locale" content="lt_LT" />

  <!-- Hreflang for Nordic countries -->
  <link rel="alternate" hreflang="lt" href="https://cranbalt.com/" />
  <link rel="alternate" hreflang="en" href="https://cranbalt.com/en/" />
  <link rel="alternate" hreflang="sv-SE" href="https://cranbalt.com/sv/" />
  <link rel="alternate" hreflang="nb-NO" href="https://cranbalt.com/no/" />

  <!-- Schema.org Structured Data -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Cranbalt",
      "url": "https://cranbalt.com",
      "logo": "https://cranbalt.com/wp-content/uploads/2017/12/logo.svg",
      "description": "Tower crane rental and industrial crane manufacturing in Baltics and Nordic countries",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Dvaro str. 162A",
        "addressLocality": "Šiauliai",
        "addressCountry": "LT"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+37041453595",
        "contactType": "customer service"
      }
    }
  </script>

  <style>
    /* Same styling as before - keeping it clean */
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: Arial, Helvetica, sans-serif; color: #333; line-height: 1.6; }
    nav { background: #00141f; color: white; position: fixed; width: 100%; top: 0; z-index: 1000; padding: 1rem 5%; }
    .nav-container { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    .logo img { height: 55px; }
    .nav-links a { color: white; margin-left: 2rem; text-decoration: none; font-weight: bold; }

    .hero { height: 100vh; min-height: 700px; position: relative; display: flex; align-items: center; justify-content: center; text-align: center; color: white; margin-top: 70px; }
    .hero video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; }
    .hero::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 10, 25, 0.85); z-index: -1; }

    .hero-content h1 { font-size: 3.3rem; margin-bottom: 1rem; text-shadow: 0 4px 15px rgba(0,0,0,0.9); }
    .hero-content p { font-size: 1.4rem; max-width: 820px; margin: 0 auto 2rem; text-shadow: 0 3px 12px rgba(0,0,0,0.9); }

    .btn { background: #f9b03f; color: #00141f; padding: 16px 42px; text-decoration: none; border-radius: 6px; font-weight: bold; display: inline-block; }
  </style>
</head>
<body>

  <nav>
    <div class="nav-container">
      <div class="logo">
        <img src="https://cranbalt.com/wp-content/uploads/2017/12/logo.svg" alt="Cranbalt Logo">
      </div>
      <div class="nav-links">
        <a href="#">Tower Cranes</a>
        <a href="#">Manufacturing</a>
        <a href="#">Projects</a>
        <a href="#">About Us</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </nav>

  <section class="hero">
    <video autoplay muted loop playsinline>
      <source src="https://cranbalt.com/wp-content/themes/cranbalt-theme/assets/img/video.mp4" type="video/mp4">
    </video>
    <div class="hero-content">
      <h1>Half a century of lifting solutions</h1>
      <p>The highest quality tower cranes rental, manufacturing of industrial cranes and steel constructions.</p>
      <a href="#services" class="btn">Find Out More</a>
    </div>
  </section>

  <!-- Rest of your content (cards, etc.) remains the same -->

</body>
</html>
