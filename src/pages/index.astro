---
const title = "Cranbalt — Tower Cranes & Steel Structures";
---

<html lang="lt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Cranbalt - Tower crane rental, manufacturing of industrial cranes and steel structures." />
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: Arial, Helvetica, sans-serif; color: #333; }

    /* Navigation - Darker Blue-Green */
    nav {
      background: #002b24;   /* Darker, more blue-green */
      color: white;
      position: fixed;
      width: 100%;
      top: 0;
      z-index: 1000;
      padding: 1rem 5%;
    }
    .nav-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo img { height: 55px; }

    .nav-links a {
      color: white;
      margin-left: 2rem;
      text-decoration: none;
      font-weight: bold;        /* Made bold as requested */
      font-size: 1.05rem;
    }

    /* Hero with Real Video */
    .hero {
      height: 100vh;
      min-height: 700px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
      margin-top: 70px;
    }
    .hero video {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      z-index: -1;
    }

    .hero-content h1 {
      font-size: 3.2rem;
      margin-bottom: 1rem;
    }
    .hero-content p {
      font-size: 1.35rem;
      max-width: 800px;
      margin: 0 auto 2rem;
    }
    .btn {
      background: #f9b03f;
      color: #002b24;
      padding: 16px 40px;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      display: inline-block;
    }

    /* Content */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 20px;
    }
    h2 { color: #002b24; margin-bottom: 1rem; }

    /* Footer */
    footer {
      background: #002b24;
      color: white;
      text-align: center;
      padding: 40px 20px;
    }
    .social a {
      color: white;
      font-size: 28px;
      margin: 0 15px;
    }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav>
    <div class="nav-container">
      <div class="logo">
        <img src="https://cranbalt.com/wp-content/uploads/2017/12/logo.svg" alt="Cranbalt Logo">
      </div>
      <div class="nav-links">
        <a href="#">Tower Cranes</a>
        <a href="#">Manufacturing</a>
        <a href="#">Projects</a>
        <a href="#">About Us</a>
        <a href="#">Contact</a>
      </div>
    </div>
  </nav>

  <!-- Hero with Real Video -->
  <section class="hero">
    <video autoplay muted loop playsinline>
      <source src="https://cranbalt.com/wp-content/themes/cranbalt-theme/assets/img/video.mp4" type="video/mp4">
    </video>

    <div class="hero-content">
      <h1>Half a century of lifting solutions</h1>
      <p>The highest quality tower cranes rental, manufacturing of industrial cranes and steel constructions.</p>
      <a href="#services" class="btn">Find Out More</a>
    </div>
  </section>

  <!-- Content -->
  <div class="container" id="services">
    <h2>Tower crane rent</h2>
    <p>Cranbalt offers a wide range of tower cranes (8t to 40t) in Baltic and Nordic countries.</p>

    <h2>Manufacturing</h2>
    <p>We manufacture bridge cranes, gantry cranes, steel structures, cantilever racks and other heavy equipment.</p>
  </div>

  <!-- Footer -->
  <footer>
    <p>© 2026 AB CRANBALT</p>
    <div class="social" style="margin-top: 15px;">
      <a href="https://www.linkedin.com/company/plc-cranbalt-" target="_blank">in</a>
      <a href="https://www.facebook.com/cranbalt/" target="_blank">f</a>
    </div>
  </footer>

</body>
</html>
