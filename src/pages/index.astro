---
const title = "Tower Crane Rental & Industrial Crane Manufacturing | Cranbalt";
const description = "Cranbalt offers tower crane rental (8-40t) and professional industrial crane manufacturing & steel structures in Sweden, Norway, and the Baltics. Reliable lifting solutions since 1966.";
---

<html lang="lt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://cranbalt.com/" />

  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: Arial, Helvetica, sans-serif; color: #333; line-height: 1.6; }

    nav { background: #00141f; color: white; position: fixed; width: 100%; top: 0; z-index: 1000; padding: 1rem 5%; }
    .nav-container { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
    .logo img { height: 55px; }
    .nav-links a { color: white; margin-left: 2rem; text-decoration: none; font-weight: bold; }

    .hero {
      height: 100vh;
      min-height: 700px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
      margin-top: 70px;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0, 10, 25, 0.85);
      z-index: -1;
    }

    .hero-content h1 { font-size: 3.3rem; margin-bottom: 1rem; text-shadow: 0 4px 15px rgba(0,0,0,0.9); }
    .hero-content p { font-size: 1.4rem; max-width: 820px; margin: 0 auto 2rem; text-shadow: 0 3px 12px rgba(0,0,0,0.9); }

    .btn {
      background: #f9b03f;
      color: #00141f;
      padding: 16px 42px;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      display: inline-block;
    }

    .services {
      display: flex;
      gap: 40px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 20px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      width: 100%;
      max-width: 520px;
      overflow: hidden;
    }
    .card img { width: 100%; height: 220px; object-fit: cover; }
    .card-content { padding: 30px; }
    .card h3 { color: #00141f; margin-bottom: 15px; }

    .who-we-are {
      max-width: 1200px;
      margin: 0 auto;
      padding: 60px 20px;
      background: #f8f9fa;
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-container">
      <div class="logo">
        <img src="https://cranbalt.com/wp-content/uploads/2017/12/logo.svg" alt="Cranbalt Logo">
      </div>
      <div class="nav-links">
        <a href="#">Tower Cranes</a>
        <a href="#">Manufacturing</a>
        <a href="#">Projects</a>
        <a href="#">About Us</a>
        <a href="/contact">Contact</a>
      </div>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <h1>Tower Crane Rental & Industrial Crane Manufacturing</h1>
      <p>The highest quality tower cranes rental, manufacturing of industrial cranes and steel constructions in Sweden, Norway and the Baltics.</p>
      <a href="#services" class="btn">Find Out More</a>
    </div>
  </section>

  <div class="services" id="services">
    <div class="card">
      <img src="https://cranbalt.com/wp-content/uploads/2018/03/Tower-crane-rental-sweden-cranbalt-336x180.jpg" alt="Tower Crane Rental">
      <div class="card-content">
        <h3>Tower crane rent</h3>
        <p>Cranbalt offers a wide range of tower cranes (8t to 40t) in Baltic and Nordic countries.</p>
        <a href="#" style="color:#f9b03f; font-weight:bold;">MORE →</a>
      </div>
    </div>

    <div class="card">
      <img src="https://cranbalt.com/wp-content/uploads/2018/02/industrial-crane-cranbalt-336x180.jpg" alt="Industrial Crane Manufacturing">
      <div class="card-content">
        <h3>Manufacturing</h3>
        <p>We manufacture various models of industrial cranes, beams, cantilever racks, and other steel structures.</p>
        <a href="#" style="color:#f9b03f; font-weight:bold;">MORE →</a>
      </div>
    </div>
  </div>

  <!-- Who we are Section -->
  <div class="who-we-are">
    <h2 style="color:#00141f; text-align:center; margin-bottom:30px;">Who we are</h2>
    <p style="max-width:1000px; margin:0 auto 25px; text-align:center;">
      With roots in heavy equipment manufacturing that date back to 1966, our company has combined experience with contemporary technologies and today is able to provide our customers with the most innovative and most professional solutions.
    </p>
    <p style="max-width:1000px; margin:0 auto 25px; text-align:center;">
      Having started with tower crane rental services within the confines of Šiauliai region, today being the authorised dealer of Terex Corporation, we specialise in both the hire and manufacture of industrial cranes and steel structures in the entire Baltic and Nordic market. Currently, we can offer the maximum range of tower cranes for rent as well as technical solutions in the manufacturing sector for sale.
    </p>
    <p style="max-width:1000px; margin:0 auto; text-align:center;">
      In order to create the greatest possible value to the customer, we follow the LEAN system. We continually invest in production, business management, customer service processes, and long-term training programs.
    </p>
  </div>

  <!-- Contact Section -->
  <div class="contact-section" style="background:#00141f; color:white; text-align:center; padding:100px 20px;">
    <h2>Lets work together to achieve our goals</h2>
    <a href="/contact" class="btn">CONTACT US</a>
  </div>

  <footer style="background:#00141f; color:white; text-align:center; padding:40px 20px;">
    <p>© 2026 AB CRANBALT</p>
    <div style="margin-top:15px;">
      <a href="https://www.facebook.com/cranbalt/" target="_blank" style="color:white; font-size:32px; margin:0 20px;">f</a>
      <a href="https://www.linkedin.com/company/plc-cranbalt-" target="_blank" style="color:white; font-size:32px; margin:0 20px;">in</a>
    </div>
  </footer>

</body>
</html>
