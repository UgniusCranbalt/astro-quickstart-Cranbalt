---
const title = "Cranbalt — Tower Cranes & Steel Structures";
---

<html lang="lt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Cranbalt - Tower crane rental, manufacturing of industrial cranes and steel structures." />
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family: Arial, Helvetica, sans-serif; color: #333; line-height: 1.6; }

    /* Navigation - Darker & More Blueish */
    nav {
      background: #00141f;     /* Much darker + blueish */
      color: white;
      position: fixed;
      width: 100%;
      top: 0;
      z-index: 1000;
      padding: 1rem 5%;
    }
    .nav-container {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .logo img { height: 55px; }
    .nav-links a {
      color: white;
      margin-left: 2rem;
      text-decoration: none;
      font-weight: bold;
    }

    /* Hero - Even Stronger Dark Overlay */
    .hero {
      height: 100vh;
      min-height: 700px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
      margin-top: 70px;
    }
    .hero video {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      z-index: -2;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0, 10, 25, 0.85);   /* Stronger blueish dark overlay */
      z-index: -1;
    }

    .hero-content h1 { 
      font-size: 3.3rem; 
      margin-bottom: 1rem; 
      text-shadow: 0 4px 15px rgba(0,0,0,0.9); 
    }
    .hero-content p { 
      font-size: 1.4rem; 
      max-width: 820px; 
      margin: 0 auto 2rem; 
      text-shadow: 0 3px 12px rgba(0,0,0,0.9); 
    }

    .btn {
      background: #f9b03f;
      color: #00141f;
      padding: 16px 42px;
      text-decoration: none;
      border-radius: 6px;
      font-weight: bold;
      display: inline-block;
    }

    /* Services Cards */
    .services {
      display: flex;
      gap: 40px;
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 20px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .card {
      background: white;
      border-radius: 8px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      width: 100%;
      max-width: 520px;
      overflow: hidden;
    }
    .card img { width: 100%; height: 220px; object-fit: cover; }
    .card-content { padding: 30px; }
    .card h3 { color: #00141f; margin-bottom: 15px; }

    /* Contact Section */
    .contact-section {
      background: #00141f;
      color: white;
      text-align: center;
      padding: 100px 20px;
    }

    footer {
      background: #00141f;
      color: white;
      text-align: center;
      padding: 40px 20px;
    }
    .social a {
      color: white;
      font-size: 32px;
      margin: 0 20px;
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-container">
      <div class="logo">
        <img src="https://cranbalt.com/wp-content/uploads/2017/12/logo.svg" alt="Cranbalt Logo">
      </div>
      <div class="nav-links">
        <a href="#">Tower Cranes</a>
        <a href="#">Manufacturing</a>
        <a href="#">Projects</a>
        <a href="#">About Us</a>
        <a href="#">Contact</a>
      </div>
    </div>
  </nav>

  <section class="hero">
    <video autoplay muted loop playsinline>
      <source src="https://cranbalt.com/wp-content/themes/cranbalt-theme/assets/img/video.mp4" type="video/mp4">
    </video>
    <div class="hero-content">
      <h1>Half a century of lifting solutions</h1>
      <p>The highest quality tower cranes rental, manufacturing of industrial cranes and steel constructions.</p>
      <a href="#services" class="btn">Find Out More</a>
    </div>
  </section>

  <div class="services" id="services">
    <div class="card">
      <img src="https://cranbalt.com/wp-content/uploads/2018/03/Tower-crane-rental-sweden-cranbalt-336x180.jpg" alt="Tower Crane Rent">
      <div class="card-content">
        <h3>Tower crane rent</h3>
        <p>Cranbalt offers a wide range of tower cranes (8t to 40t) in Baltic and Nordic countries.</p>
        <a href="#" style="color:#f9b03f; font-weight:bold;">MORE →</a>
      </div>
    </div>

    <div class="card">
      <img src="https://cranbalt.com/wp-content/uploads/2018/02/industrial-crane-cranbalt-336x180.jpg" alt="Manufacturing">
      <div class="card-content">
        <h3>Manufacturing</h3>
        <p>We manufacture various models of industrial cranes, beams, cantilever racks, and other steel structures.</p>
        <a href="#" style="color:#f9b03f; font-weight:bold;">MORE →</a>
      </div>
    </div>
  </div>

  <div class="contact-section">
    <h2>Lets work together to achieve our goals</h2>
    <a href="#" class="btn" style="background:#f9b03f; color:#00141f;">CONTACT US</a>
  </div>

  <footer>
    <p>© 2026 AB CRANBALT</p>
    <div class="social">
      <a href="https://www.facebook.com/cranbalt/" target="_blank">f</a>
      <a href="https://www.linkedin.com/company/plc-cranbalt-" target="_blank">in</a>
    </div>
  </footer>

</body>
</html>
